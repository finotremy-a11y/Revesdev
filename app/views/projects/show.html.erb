<% content_for :title, "#{@project.title} - RêvesDev" %>

<main class="pt-32 pb-20 px-4 max-w-5xl mx-auto">
  <%= link_to projects_path, class: "inline-flex items-center text-slate-400 hover:text-primary transition-colors mb-8" do %>
    <i class="ri-arrow-left-line mr-2"></i> Retour au portfolio
  <% end %>

  <div class="glass p-1 rounded-3xl overflow-hidden mb-12">
    <% if @project.cover_image.attached? %>
      <%= image_tag @project.cover_image, class: "w-full aspect-video object-cover rounded-[1.3rem]" %>
    <% else %>
      <div class="w-full aspect-video bg-slate-800 rounded-[1.3rem] flex items-center justify-center">
        <span class="text-slate-500 font-mono">[Sans image de couverture]</span>
      </div>
    <% end %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
    <div class="md:col-span-2">
      <h1 class="font-heading text-4xl md:text-5xl font-bold mb-6"><%= @project.title %></h1>
      
      <div class="prose prose-invert prose-lg max-w-none text-slate-300">
        <%= simple_format @project.description %>
      </div>
    </div>

    <div class="space-y-8">
      <% if @project.tech_stack.present? %>
        <div class="glass p-6 rounded-2xl">
          <h3 class="font-bold text-lg mb-4 text-white">Technologies</h3>
          <div class="flex flex-wrap gap-2">
            <% @project.tech_stack.split(',').each do |tech| %>
              <span class="inline-block px-3 py-1 bg-white/5 border border-white/10 rounded-full text-sm font-medium text-slate-300">
                <%= tech.strip %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @project.live_url.present? || @project.repo_url.present? %>
        <div class="glass p-6 rounded-2xl flex flex-col gap-4">
          <h3 class="font-bold text-lg text-white mb-2">Liens du projet</h3>
          
          <% if @project.live_url.present? %>
            <%= link_to @project.live_url, target: "_blank", class: "flex items-center justify-center w-full bg-primary hover:bg-indigo-600 text-white px-4 py-3 rounded-xl font-medium transition-colors" do %>
              <i class="ri-external-link-line mr-2"></i> Voir le site en ligne
            <% end %>
          <% end %>

          <% if @project.repo_url.present? %>
            <%= link_to @project.repo_url, target: "_blank", class: "flex items-center justify-center w-full bg-white/5 hover:bg-white/10 border border-white/10 text-white px-4 py-3 rounded-xl font-medium transition-colors" do %>
              <i class="ri-github-fill mr-2 text-lg"></i> Code source
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</main>
