<div class="max-w-4xl mx-auto px-4 py-20 mt-20">
    <div class="text-center mb-16">
        <h1 class="font-heading text-4xl md:text-5xl font-bold mb-4">Travaillons <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">ensemble</span></h1>
        <p class="text-slate-400 text-lg">Décrivez-moi votre projet, vos besoins ou vos questions, je vous répondrai dans les plus brefs délais.</p>
    </div>

    <div class="glass p-8 md:p-12 rounded-2xl max-w-2xl mx-auto">
        <%= form_with model: @contact, url: contacts_path, class: "space-y-6" do |f| %>
            
            <% if @contact.errors.any? %>
                <div class="p-4 mb-6 bg-red-500/10 border border-red-500/20 rounded-lg">
                    <h2 class="text-red-400 font-semibold mb-2"><%= pluralize(@contact.errors.count, "erreur a empêché", "erreurs ont empêché") %> l'envoi de votre message :</h2>
                    <ul class="list-disc list-inside text-red-300 text-sm space-y-1">
                        <% @contact.errors.full_messages.each do |msg| %>
                            <li><%= msg %></li>
                        <% end %>
                    </ul>
                </div>
            <% end %>

            <div class="grid grid-cols-1 select-none md:grid-cols-2 gap-6">
                <div>
                    <%= f.label :name, "Votre Nom", class: "block text-sm font-medium text-slate-300 mb-2" %>
                    <%= f.text_field :name, class: "w-full bg-slate-900/50 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all", placeholder: "Jean Dupont", required: true %>
                </div>
                <div>
                    <%= f.label :email, "Adresse Email", class: "block text-sm font-medium text-slate-300 mb-2" %>
                    <%= f.email_field :email, class: "w-full bg-slate-900/50 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all", placeholder: "jean@exemple.com", required: true %>
                </div>
            </div>

            <div>
                <%= f.label :subject, "Sujet", class: "block text-sm font-medium text-slate-300 mb-2" %>
                <%= f.text_field :subject, class: "w-full bg-slate-900/50 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all", placeholder: "Sujet de votre message" %>
            </div>

            <div>
                <%= f.label :message, "Message", class: "block text-sm font-medium text-slate-300 mb-2" %>
                <%= f.text_area :message, rows: 6, class: "w-full bg-slate-900/50 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all resize-y", placeholder: "Parlez-moi de votre projet...", required: true %>
            </div>

            <div class="pt-4 text-center pb-2">
                <%= f.submit "Envoyer le Message", class: "w-full md:w-auto bg-primary hover:bg-indigo-600 text-white font-bold py-4 px-10 rounded-full cursor-pointer transition-all duration-300 shadow-[0_4px_14px_0_rgb(99,102,241,0.39)] hover:shadow-[0_6px_20px_rgba(99,102,241,0.23)] hover:-translate-y-0.5", data: { turbo_submits_with: "Envoi en cours..." } %>
            </div>
        <% end %>
    </div>
</div>
