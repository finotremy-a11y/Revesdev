<div class="mb-8 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
  <div>
    <h1 class="text-3xl font-bold font-heading mb-2">Portfolio</h1>
    <p class="text-slate-500 dark:text-slate-400">Gérez les projets affichés sur votre site.</p>
  </div>
  <%= link_to new_admin_project_path, class: "inline-flex items-center justify-center space-x-2 bg-primary text-white hover:bg-primary/90 transition-colors px-4 py-2 rounded-lg font-medium" do %>
      <i class="ri-add-line"></i>
      <span>Nouveau projet</span>
  <% end %>
</div>

<div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-white/10">
          <th class="px-6 py-4 font-heading font-medium text-sm text-slate-500 dark:text-slate-400">Projet</th>
          <th class="px-6 py-4 font-heading font-medium text-sm text-slate-500 dark:text-slate-400">Position</th>
          <th class="px-6 py-4 font-heading font-medium text-sm text-slate-500 dark:text-slate-400">Statut</th>
          <th class="px-6 py-4 font-heading font-medium text-sm text-slate-500 dark:text-slate-400 text-right">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200 dark:divide-white/10">
        <% if @projects.any? %>
          <% @projects.each do |project| %>
            <tr class="hover:bg-slate-50 dark:hover:bg-white/5 transition-colors">
              <td class="px-6 py-4">
                <div class="flex items-center space-x-4">
                  <div class="w-12 h-12 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center flex-shrink-0">
                    <% if project.cover_image.attached? %>
                        <%= image_tag project.cover_image.variant(resize_to_limit: [100, 100]), class: "w-full h-full object-cover rounded-lg" %>
                    <% else %>
                        <i class="ri-image-line text-slate-400"></i>
                    <% end %>
                  </div>
                  <div>
                    <p class="font-bold"><%= project.title %></p>
                    <p class="text-sm text-slate-500 dark:text-slate-400 truncate max-w-[250px]"><%= project.description %></p>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4">
                <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-slate-100 dark:bg-slate-800 text-sm font-medium">
                  <%= project.position.presence || "-" %>
                </span>
              </td>
              <td class="px-6 py-4">
                <% if project.featured %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400 border border-amber-200 dark:border-amber-800">
                    En vedette
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-800 dark:bg-slate-800 dark:text-slate-300 border border-slate-200 dark:border-white/10">
                    Standard
                  </span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-right space-x-2">
                <%= link_to edit_admin_project_path(project), class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-slate-500 hover:text-primary hover:bg-primary/10 transition-colors" do %>
                  <i class="ri-edit-line"></i>
                <% end %>
                <%= button_to admin_project_path(project), method: :delete, data: { turbo_confirm: "Êtes-vous sûr de vouloir supprimer ce projet ?" }, class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-slate-500 hover:text-red-500 hover:bg-red-500/10 transition-colors" do %>
                  <i class="ri-delete-bin-line"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="4" class="px-6 py-12 text-center text-slate-500">
              <i class="ri-folder-open-line text-4xl mb-3 inline-block"></i>
              <p>Aucun projet dans le portfolio.</p>
              <%= link_to "Ajouter le premier projet", new_admin_project_path, class: "text-primary hover:underline mt-2 inline-block" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
