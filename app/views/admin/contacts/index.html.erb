<div class="mb-8">
  <h1 class="text-3xl font-bold font-heading mb-2">Messages</h1>
  <p class="text-slate-500 dark:text-slate-400">Consultez les demandes de contact reçues depuis le site.</p>
</div>

<div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-white/10">
          <th class="px-6 py-4 font-heading font-medium text-sm text-slate-500 dark:text-slate-400">Expéditeur</th>
          <th class="px-6 py-4 font-heading font-medium text-sm text-slate-500 dark:text-slate-400">Date</th>
          <th class="px-6 py-4 font-heading font-medium text-sm text-slate-500 dark:text-slate-400">Statut</th>
          <th class="px-6 py-4 font-heading font-medium text-sm text-slate-500 dark:text-slate-400 text-right">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200 dark:divide-white/10">
        <% if @contacts.any? %>
          <% @contacts.each do |contact| %>
            <tr class="hover:bg-slate-50 dark:hover:bg-white/5 transition-colors <%= !contact.read_status ? 'bg-primary/5 dark:bg-primary/10' : '' %>">
              <td class="px-6 py-4">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 rounded-full bg-slate-200 dark:bg-slate-800 flex items-center justify-center text-slate-500 font-bold font-heading uppercase">
                        <%= contact.name.first %>
                    </div>
                    <div>
                        <p class="font-bold <%= !contact.read_status ? 'text-primary' : '' %>"><%= contact.name %></p>
                        <p class="text-sm text-slate-500 dark:text-slate-400"><%= contact.email %></p>
                    </div>
                </div>
              </td>
              <td class="px-6 py-4 text-slate-500 dark:text-slate-400 text-sm">
                <%= contact.created_at.strftime("%d/%m/%Y à %H:%M") %>
              </td>
              <td class="px-6 py-4">
                <% if contact.read_status %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-800 dark:bg-slate-800 dark:text-slate-300">
                    Lu
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary/10 text-primary border border-primary/20">
                    Nouveau
                  </span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-right space-x-2">
                <%= link_to admin_contact_path(contact), class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-slate-500 hover:text-primary hover:bg-primary/10 transition-colors" do %>
                  <i class="ri-eye-line"></i>
                <% end %>
                <%= button_to admin_contact_path(contact), method: :delete, data: { turbo_confirm: "Êtes-vous sûr de supprimer ce message ?" }, class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-slate-500 hover:text-red-500 hover:bg-red-500/10 transition-colors" do %>
                  <i class="ri-delete-bin-line"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="4" class="px-6 py-12 text-center text-slate-500">
              <i class="ri-mail-check-line text-4xl mb-3 inline-block"></i>
              <p>Votre boîte de réception est vide.</p>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
