<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nouveau message — RêvesDev</title>
</head>
<body style="margin:0;padding:0;background-color:#020617;font-family:'Inter',Arial,sans-serif;">

  <!-- Wrapper -->
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color:#020617;">
    <tr>
      <td align="center" style="padding:40px 16px;">

        <!-- Card -->
        <table role="presentation" width="100%" style="max-width:600px;background-color:#0f172a;border-radius:16px;border:1px solid #1e293b;overflow:hidden;">

          <!-- Header -->
          <tr>
            <td style="background:linear-gradient(135deg,#6366f1,#22d3ee);padding:40px 40px 32px;">
              <p style="margin:0 0 8px;font-size:12px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.7);">RêvesDev</p>
              <h1 style="margin:0;font-size:26px;font-weight:700;color:#ffffff;line-height:1.3;">Nouveau message reçu 📬</h1>
              <p style="margin:8px 0 0;font-size:14px;color:rgba(255,255,255,0.75);">Via le formulaire de contact — <%= Time.current.strftime("%d %B %Y à %H:%M") %></p>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding:36px 40px;">

              <!-- Intro -->
              <p style="margin:0 0 28px;font-size:15px;color:#94a3b8;line-height:1.6;">Un visiteur a rempli le formulaire de contact sur ton site. Voici les détails du message :</p>

              <!-- Info blocks -->
              <table role="presentation" width="100%" style="margin-bottom:28px;">
                <tr>
                  <td style="padding:0 0 16px;">
                    <table role="presentation" width="100%" style="background-color:#1e293b;border-radius:12px;overflow:hidden;">
                      <tr>
                        <td style="padding:16px 20px;">
                          <p style="margin:0 0 4px;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#6366f1;">Expéditeur</p>
                          <p style="margin:0;font-size:16px;font-weight:600;color:#f8fafc;"><%= @contact.name %></p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding:0 0 16px;">
                    <table role="presentation" width="100%" style="background-color:#1e293b;border-radius:12px;overflow:hidden;">
                      <tr>
                        <td style="padding:16px 20px;">
                          <p style="margin:0 0 4px;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#6366f1;">Adresse e-mail</p>
                          <a href="mailto:<%= @contact.email %>" style="margin:0;font-size:15px;font-weight:500;color:#22d3ee;text-decoration:none;"><%= @contact.email %></a>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <% if @contact.subject.present? %>
                <tr>
                  <td style="padding:0 0 16px;">
                    <table role="presentation" width="100%" style="background-color:#1e293b;border-radius:12px;overflow:hidden;">
                      <tr>
                        <td style="padding:16px 20px;">
                          <p style="margin:0 0 4px;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#6366f1;">Sujet</p>
                          <p style="margin:0;font-size:15px;font-weight:500;color:#f8fafc;"><%= @contact.subject %></p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <% end %>
              </table>

              <!-- Message -->
              <table role="presentation" width="100%" style="margin-bottom:36px;">
                <tr>
                  <td style="background-color:#1e293b;border-radius:12px;border-left:3px solid #6366f1;padding:20px 24px;">
                    <p style="margin:0 0 8px;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#6366f1;">Message</p>
                    <p style="margin:0;font-size:15px;color:#cbd5e1;line-height:1.8;white-space:pre-wrap;"><%= @contact.message %></p>
                  </td>
                </tr>
              </table>

              <!-- CTA Button -->
              <table role="presentation" cellspacing="0" cellpadding="0">
                <tr>
                  <td style="border-radius:50px;background:linear-gradient(135deg,#6366f1,#22d3ee);">
                    <a href="mailto:<%= @contact.email %>?subject=Re: <%= @contact.subject.presence || 'Votre message' %>&body=Bonjour <%= @contact.name %>,%0A%0A"
                      style="display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;border-radius:50px;">
                      Répondre à <%= @contact.name %> →
                    </a>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding:24px 40px;border-top:1px solid #1e293b;">
              <p style="margin:0;font-size:12px;color:#475569;text-align:center;line-height:1.6;">
                Notification automatique · <a href="https://revesdev.fr" style="color:#6366f1;text-decoration:none;">revesdev.fr</a>
                <br>Ce message a été envoyé depuis le formulaire de contact de ton site.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
