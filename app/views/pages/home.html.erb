<!-- Hero Section -->
<main class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden">
    <!-- Glow effects de fond -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-lg h-[500px] bg-primary/20 rounded-full blur-[120px] -z-10 pointer-events-none"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="inline-block py-1 px-3 rounded-full bg-white/5 border border-white/10 text-secondary text-sm font-semibold tracking-wide mb-6">
            🚀 Disponible pour de nouveaux projets
        </span>
        <h1 class="font-heading text-5xl md:text-7xl font-extrabold tracking-tight mb-8">
            Je transforme vos idées en <br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">Applications Web Performantes</span>
        </h1>
        <p class="mt-4 max-w-2xl mx-auto text-xl text-slate-400 mb-10">
            Développeur Full-Stack (Ruby on Rails / React) spécialisé dans la création de SaaS, Marketplaces et architectures complexes.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
            <%= link_to projects_path, class: "bg-primary hover:bg-indigo-600 text-white px-8 py-4 rounded-full font-semibold transition-all duration-300 shadow-[0_4px_14px_0_rgb(99,102,241,0.39)] hover:shadow-[0_6px_20px_rgba(99,102,241,0.23)] hover:-translate-y-1" do %>
                Voir mes Réalisations
            <% end %>
            <%= link_to new_contact_path, class: "glass text-white px-8 py-4 rounded-full font-semibold hover:bg-white/10 transition-all duration-300" do %>
                Discuter de votre Projet
            <% end %>
        </div>
    </div>
</main>

<!-- Services Section -->
<section id="services" class="py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="font-heading text-3xl md:text-4xl font-bold">Mon Expertise Technique</h2>
            <p class="mt-4 text-slate-400">De la conception de la base de données à l'interface utilisateur.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Service 1 -->
            <div class="glass p-8 rounded-2xl hover:-translate-y-2 transition-transform duration-300 group">
                <div class="w-14 h-14 rounded-xl bg-primary/20 flex items-center justify-center mb-6 text-primary group-hover:scale-110 transition-transform">
                    <i class="ri-code-s-slash-line text-2xl"></i>
                </div>
                <h3 class="text-xl font-bold font-heading mb-3">Développement Front-End</h3>
                <p class="text-slate-400 leading-relaxed">
                    Création d'interfaces modernes, réactives et accessibles avec React, Hotwire, ou Tailwind CSS. Focus sur l'expérience et la performance.
                </p>
            </div>
            <!-- Service 2 -->
            <div class="glass p-8 rounded-2xl hover:-translate-y-2 transition-transform duration-300 group">
                <div class="w-14 h-14 rounded-xl bg-secondary/20 flex items-center justify-center mb-6 text-secondary group-hover:scale-110 transition-transform">
                    <i class="ri-server-line text-2xl"></i>
                </div>
                <h3 class="text-xl font-bold font-heading mb-3">Architecture Back-End</h3>
                <p class="text-slate-400 leading-relaxed">
                    Conception d'APIs robustes, structuration de base de données (PostgreSQL) et logique métier avec Ruby on Rails.
                </p>
            </div>
            <!-- Service 3 -->
            <div class="glass p-8 rounded-2xl hover:-translate-y-2 transition-transform duration-300 group">
                <div class="w-14 h-14 rounded-xl bg-purple-500/20 flex items-center justify-center mb-6 text-purple-400 group-hover:scale-110 transition-transform">
                    <i class="ri-rocket-line text-2xl"></i>
                </div>
                <h3 class="text-xl font-bold font-heading mb-3">Déploiement & DevOps</h3>
                <p class="text-slate-400 leading-relaxed">
                    Mise en production sécurisée, intégration continue (CI/CD), conteneurisation et hébergement cloud performant.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Project Teaser Section -->
<section id="portfolio" class="py-24 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-end mb-12">
            <div>
                <h2 class="font-heading text-3xl md:text-4xl font-bold">Projets Récents</h2>
                <p class="mt-4 text-slate-400">Quelques exemples de réalisations récentes.</p>
            </div>
            <%= link_to projects_path, class: "hidden sm:inline-flex items-center text-primary font-medium hover:text-indigo-400 hover:underline underline-offset-4" do %>
                Voir tout le portfolio <i class="ri-arrow-right-line ml-2"></i>
            <% end %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <% if @featured_projects.any? %>
                <% @featured_projects.each do |project| %>
                    <%= link_to project, class: "group relative rounded-2xl overflow-hidden glass block" do %>
                        <div class="aspect-video bg-slate-800 relative w-full flex items-center justify-center">
                            <% if project.cover_image.attached? %>
                                <%= image_tag project.cover_image, class: "absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" %>
                            <% else %>
                                <span class="text-slate-500 font-mono text-sm">[Sans image]</span>
                            <% end %>
                            <div class="absolute inset-0 bg-gradient-to-t from-background/90 via-background/40 to-transparent opacity-60 group-hover:opacity-80 transition-opacity"></div>
                        </div>
                        <div class="absolute bottom-0 left-0 p-8 w-full translate-y-4 group-hover:translate-y-0 transition-transform">
                            <% if project.tech_stack.present? %>
                                <div class="flex flex-wrap gap-2 mb-3">
                                    <% project.tech_stack.split(',').each do |tech| %>
                                        <span class="text-xs font-semibold bg-white/10 px-2 py-1 rounded backdrop-blur-sm"><%= tech.strip %></span>
                                    <% end %>
                                </div>
                            <% end %>
                            <h3 class="text-2xl font-bold font-heading"><%= project.title %></h3>
                            <p class="text-slate-300 mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300"><%= truncate(project.description, length: 100) %></p>
                        </div>
                    <% end %>
                <% end %>
            <% else %>
                <div class="col-span-full text-center text-slate-500 py-12">
                     <p>Aucun projet en vedette pour le moment.</p>
                </div>
            <% end %>
        </div>
    </div>
</section>
